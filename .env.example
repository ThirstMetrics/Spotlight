# ===========================================
# Spotlight Environment Variables
# ===========================================

# Database (Docker Postgres for local dev)
DATABASE_URL=postgresql://spotlight:spotlight@localhost:5432/spotlight?schema=public

# Supabase (when using hosted Supabase)
# NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_PORTAL_URL=http://localhost:3001

# Auth (local JWT for Docker mode)
JWT_SECRET=local-dev-jwt-secret-change-in-production

# Map (Mapbox)
# NEXT_PUBLIC_MAP_TOKEN=your-mapbox-token

# Docker (on-premise only)
POSTGRES_USER=spotlight
POSTGRES_PASSWORD=spotlight
POSTGRES_DB=spotlight
REDIS_URL=redis://localhost:6379
